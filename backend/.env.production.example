# Backend environment for production deployment
# Used for Railway, Render, or similar platforms

PORT=4000
NODE_ENV=production
CORS_ORIGIN=https://your-frontend-domain.vercel.app
API_BASE_PATH=/

# JWT Configuration - CHANGE THESE IN PRODUCTION
JWT_SECRET=your-strong-secret-key-change-in-production
JWT_EXPIRES_IN=1d

# Database Configuration - Use environment-specific values
# For Railway/Render: Use connection string from service
DB_HOST=your-db-host.railway.app
DB_PORT=3306
DB_USER=postgres
DB_PASSWORD=your-secure-password
DB_NAME=smartseason
